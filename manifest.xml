<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <!-- ===============================================================
       STAP 1: Pas deze waardes aan voor jouw organisatie
       =============================================================== -->
  <Id>a1b2c3d4-e5f6-7890-abcd-ef1234567890</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Jouw Bedrijfsnaam</ProviderName>
  <DefaultLocale>nl-NL</DefaultLocale>
  <DisplayName DefaultValue="Mail naar Order"/>
  <Description DefaultValue="Verplaats een e-mail snel naar een ordermap op basis van ordernummer."/>

  <!-- ===============================================================
       STAP 2: Vervang deze URL met waar jij de bestanden host
       (bijv. https://jouwnaam.github.io/outlook-addin/)
       =============================================================== -->
  <IconUrl DefaultValue="https://tommatser-hub.github.io/outlook-order-addin/assets/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://JOUW-URL-HIER/assets/icon-80.png"/>
  <SupportUrl DefaultValue="https://tommatser-hub.github.io/outlook-order-addin/"/>

  <AppDomains>
    <!-- Voeg hier extra domeinen toe indien nodig -->
    <AppDomain>https://graph.microsoft.com</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.3"/>
    </Sets>
  </Requirements>

  <!-- Standaard fallback (oudere Outlook versies) -->
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://tommatser-hub.github.io/outlook-order-addin/taskpane.html"/>
        <RequestedHeight>450</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>

  <!-- ===============================================================
       NIEUWE OUTLOOK: Ribbon knop configuratie
       =============================================================== -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1" xsi:type="VersionOverridesV1_1">

      <Requirements>
        <bt:Sets DefaultMinVersion="1.3">
          <bt:Set Name="Mailbox"/>
        </bt:Sets>
      </Requirements>

      <Hosts>
        <Host xsi:type="MailHost">

          <!-- DesktopFormFactor = nieuwe Outlook / Outlook desktop -->
          <DesktopFormFactor>

            <FunctionFile resid="Commands.Url"/>

            <!-- Knop in de leesweergave toolbar -->
            <ExtensionPoint xsi:type="MessageReadCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="msgReadGroup">
                  <Label resid="GroupLabel"/>

                  <!-- De knop zelf -->
                  <Control xsi:type="Button" id="msgReadOpenPaneButton">
                    <Label resid="TaskpaneButton.Label"/>
                    <Supertip>
                      <Title resid="TaskpaneButton.Label"/>
                      <Description resid="TaskpaneButton.Tooltip"/>
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="Icon.16x16"/>
                      <bt:Image size="32" resid="Icon.32x32"/>
                      <bt:Image size="80" resid="Icon.80x80"/>
                    </Icon>
                    <Action xsi:type="ShowTaskpane">
                      <TaskpaneId>ButtonId1</TaskpaneId>
                      <SourceLocation resid="Taskpane.Url"/>
                    </Action>
                  </Control>

                </Group>
              </OfficeTab>
            </ExtensionPoint>

          </DesktopFormFactor>
        </Host>
      </Hosts>

      <!-- Alle teksten en URLs -->
      <Resources>
        <bt:Images>
          <bt:Image id="Icon.16x16" DefaultValue="https://JOUW-URL-HIER/assets/icon-16.png"/>
          <bt:Image id="Icon.32x32" DefaultValue="https://JOUW-URL-HIER/assets/icon-32.png"/>
          <bt:Image id="Icon.80x80" DefaultValue="https://JOUW-URL-HIER/assets/icon-80.png"/>
        </bt:Images>
        <bt:Urls>
          <bt:Url id="Commands.Url" DefaultValue="https://JOUW-URL-HIER/commands.html"/>
          <bt:Url id="Taskpane.Url" DefaultValue="https://JOUW-URL-HIER/taskpane.html"/>
        </bt:Urls>
        <bt:ShortStrings>
          <bt:String id="GroupLabel" DefaultValue="Order Tools"/>
          <bt:String id="TaskpaneButton.Label" DefaultValue="→ Naar Order"/>
        </bt:ShortStrings>
        <bt:LongStrings>
          <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Verplaats deze e-mail naar een ordermap. Voer het ordernummer in het venster in."/>
        </bt:LongStrings>
      </Resources>

    </VersionOverrides>
  </VersionOverrides>
</OfficeApp>
